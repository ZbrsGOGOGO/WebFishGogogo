# ============================================================
# 环境变量示例（复制为 .env 并按需填写；.env 不提交到仓库）
# ============================================================

# ---------- 运行模式 ----------
# 本地开发/预览：true 时使用 pg-mem 内存数据库 + 本地文件存储，无需装 PostgreSQL/S3。
# 生产环境请勿设置或设为 false。
LOCAL_DEV=true

# 后端端口（默认 3000）
PORT=3000

# ---------- 鉴权 ----------
# JWT 签名密钥（生产环境务必改为强随机值）
JWT_SECRET=change-me-in-production
# 令牌有效期（默认 7d）
JWT_EXPIRES_IN=7d

# ---------- 跨域（生产可选）----------
# 允许的前端来源，多个用逗号分隔；LOCAL_DEV=true 时自动放开本地跨域
# CORS_ORIGIN=https://your-domain.com

# ---------- PostgreSQL（生产环境，LOCAL_DEV=false 时生效）----------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=stealth_reader
DB_SCHEMA=public
DB_SSL=false
DB_LOGGING=false

# ---------- 对象存储 S3/MinIO（生产环境）----------
# STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=stealth-reader
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_KEY_PREFIX=documents

# ---------- 本地文件存储（LOCAL_DEV=true 时生效）----------
# 章节正文写入的本地目录，默认系统临时目录下的 stealth-reader-storage
# LOCAL_STORAGE_DIR=/tmp/stealth-reader-storage

# ---------- 前端（构建时注入）----------
# 前端调用的后端 API 基址，默认 http://localhost:3000/api
# VITE_API_BASE_URL=http://localhost:3000/api
